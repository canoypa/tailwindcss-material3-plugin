{
  "name": "tailwindcss-material3-plugin",
  "version": "0.3.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canoypa/tailwindcss-material3-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/canoypa/tailwindcss-material3-plugin/issues"
  },
  "homepage": "https://github.com/canoypa/tailwindcss-material3-plugin#readme",
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "format": "prettier --write src",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rollup-plugin-swc3": "^0.12.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
